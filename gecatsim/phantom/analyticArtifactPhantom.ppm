materialList = {'water' 'bone' 'ti' 'fe'};

materialList = {'polyethylene_LDPE'};

object.center(1,:)    = [0 0 0];          % center of cylinder
object.half_axes(1,:) = [62.5 62.5 0];    % in-plane radii (x,y); z half-axis often unused for cylinders
object.euler_angs(1,:)= [0 0 0];          % axis aligned (no rotation)

object.type(1)        = 2;                % keep your existing convention (library-specific)
object.shape(1)       = 1;                % <-- change from ellipsoid (0) to cylinder/elliptical-cylinder (often 1)
object.material(1)    = 1;
object.density(1)     = 1.0;

object.axial_lims(1,:)= [-35 35];         % finite height along local axis (here z)
object.clip{1}        = [];